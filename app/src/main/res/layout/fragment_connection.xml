<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".SettingFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- MQTT 标题 + 协议选择 + 眼睛图标 同行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/protocol"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="@dimen/text_h1"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/protocol"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/protocol_tcp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="TCP"
                        android:textSize="@dimen/text_body" />

                    <RadioButton
                        android:id="@+id/protocol_ssl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="SSL"
                        android:textSize="@dimen/text_body" />

                    <RadioButton
                        android:id="@+id/protocol_ws"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="WS"
                        android:textSize="@dimen/text_body" />

                    <RadioButton
                        android:id="@+id/protocol_wss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="WSS"
                        android:textSize="@dimen/text_body" />
                </RadioGroup>

                <!-- 眼睛图标按钮：切换密码明文/密文显示 -->
                <ImageButton
                    android:id="@+id/btn_toggle_password_visibility"
                    android:layout_width="@dimen/touch_target_min"
                    android:layout_height="@dimen/touch_target_min"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle password visibility"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_eye_closed" />
            </LinearLayout>

            <!-- SSL untrusted 证书 -->
            <LinearLayout
                android:id="@+id/ssl_untrusted_container"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="@dimen/spacing_xl"
                    android:layout_height="wrap_content"
                    android:text="Untrusted"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <Switch
                    android:id="@+id/allow_untrusted_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- 横屏输入框：纯EditText(不用TextInputLayout)，Label左80dp + 输入框右填充 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/spacing_xl"
                    android:layout_height="wrap_content"
                    android:text="@string/host"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/host"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/edit_text"
                    android:hint="@string/host"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_xs"
                    android:singleLine="true"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/spacing_xl"
                    android:layout_height="wrap_content"
                    android:text="@string/port"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/port"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/edit_text"
                    android:hint="@string/port"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_xs"
                    android:singleLine="true"
                    android:text="1883"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/path_container"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="@dimen/spacing_xl"
                    android:layout_height="wrap_content"
                    android:text="@string/path"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/path"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/edit_text"
                    android:hint="@string/path"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_xs"
                    android:singleLine="true"
                    android:text="/mqtt"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/spacing_xl"
                    android:layout_height="wrap_content"
                    android:text="@string/client_id"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/clientid"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/edit_text"
                    android:hint="@string/client_id"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_xs"
                    android:singleLine="true"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/spacing_xl"
                    android:layout_height="wrap_content"
                    android:text="@string/username"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/username"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/edit_text"
                    android:hint="@string/username"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_xs"
                    android:singleLine="true"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="@dimen/spacing_xl"
                    android:layout_height="wrap_content"
                    android:text="@string/password"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:drawable/edit_text"
                    android:hint="@string/password"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_xs"
                    android:paddingEnd="@dimen/spacing_xs"
                    android:singleLine="true"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_connect"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_weight="1"
                    android:text="@string/connect"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_body" />

                <Button
                    android:id="@+id/btn_disconnect"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_weight="1"
                    android:text="Disconnect"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_body" />

                <Button
                    android:id="@+id/test_popup"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_weight="1"
                    android:text="弹窗"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

            <!-- Home Assistant 区域 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="Home Assistant"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_h1"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/homeassistant_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="@dimen/spacing_xl"
                        android:layout_height="wrap_content"
                        android:text="HA Address"
                        android:textColor="#666666"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/ha_address"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:drawable/edit_text"
                        android:hint="HA Address"
                        android:inputType="text"
                        android:maxLines="1"
                        android:paddingStart="@dimen/spacing_xs"
                        android:paddingEnd="@dimen/spacing_xs"
                        android:singleLine="true"
                        android:text="homeassistant.local"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="@dimen/spacing_xl"
                        android:layout_height="wrap_content"
                        android:text="HA Token"
                        android:textColor="#666666"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/ha_token"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:drawable/edit_text"
                        android:hint="Long-lived Token"
                        android:inputType="text"
                        android:maxLines="1"
                        android:paddingStart="@dimen/spacing_xs"
                        android:paddingEnd="@dimen/spacing_xs"
                        android:singleLine="true"
                        android:text="abcdefg"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="@dimen/spacing_xl"
                        android:layout_height="wrap_content"
                        android:text="Language"
                        android:textColor="#666666"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/ha_language"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:drawable/edit_text"
                        android:hint="Language"
                        android:inputType="text"
                        android:maxLines="1"
                        android:paddingStart="@dimen/spacing_xs"
                        android:paddingEnd="@dimen/spacing_xs"
                        android:singleLine="true"
                        android:text="zh"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="@dimen/spacing_xl"
                        android:layout_height="wrap_content"
                        android:text="HTTPS"
                        android:textColor="#666666"
                        android:textSize="12sp" />

                    <Switch
                        android:id="@+id/ha_https_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <!-- HA Response Delay -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Response Delay (ms):"
                        android:textColor="#666666"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/ha_response_delay_seekbar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="199"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/ha_response_delay_value"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:text="10ms"
                        android:textSize="@dimen/text_caption"
                        android:gravity="end" />
                </LinearLayout>

                <!-- 单击替代返回开关 -->
                <Switch
                    android:id="@+id/ha_click_back_switch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="单击替代返回"
                    android:textColor="@android:color/black"
                    android:textSize="@dimen/text_body"
                    android:checked="true" />

                <!-- HA 点击次数设置 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Click Count:"
                        android:textColor="#666666"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/ha_click_count"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:drawable/edit_text"
                        android:hint="Click count"
                        android:inputType="number"
                        android:maxLines="1"
                        android:paddingStart="@dimen/spacing_xs"
                        android:paddingEnd="@dimen/spacing_xs"
                        android:singleLine="true"
                        android:text="1"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>
            </LinearLayout>

            <!-- Features 开关区 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="Features"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_h1"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="TTS (Text-to-Speech)"
                    android:textColor="@android:color/black"
                    android:textSize="12sp" />

                <Switch
                    android:id="@+id/tts_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Float Window"
                    android:textColor="@android:color/black"
                    android:textSize="12sp" />

                <Switch
                    android:id="@+id/float_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Auto Capture Voice"
                    android:textColor="@android:color/black"
                    android:textSize="12sp" />

                <Switch
                    android:id="@+id/voice_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Auto Start (Reboot)"
                    android:textColor="@android:color/black"
                    android:textSize="12sp" />

                <Switch
                    android:id="@+id/auto_start_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:text="Persistent Notification"
                    android:textColor="@android:color/black"
                    android:textSize="12sp" />

                <Switch
                    android:id="@+id/notification_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- ========== 车机无障碍永久化：ADB说明按钮 ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="车机保活设置 (BYD)"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_h1"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="点击查看ADB命令，实现重启后无障碍不失效"
                android:textColor="#666666"
                android:textSize="@dimen/text_body"

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_adb_guide"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_weight="1"
                    android:text="ADB说明"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_body"

                <Button
                    android:id="@+id/btn_byd_whitelist"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_weight="1"
                    android:text="极速白名单"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_body"

                <Button
                    android:id="@+id/btn_battery_opt"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_weight="1"
                    android:text="电池优化"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_body"

                <Button
                    android:id="@+id/btn_autostart"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_weight="1"
                    android:text="自启动"
                    android:textAllCaps="false"
                    android:textSize="@dimen/text_body"
            </LinearLayout>


            <!-- ========== 云端TTS设置（横屏紧凑版） ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="Cloud TTS Settings"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_h2"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.8"
                    android:text="API:"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/cloud_tts_api_spinner"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1.5" />

                <Button
                    android:id="@+id/btn_tts_test_cloud"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="Test"
                    android:textAllCaps="false"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/btn_tts_reset_default"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_weight="1"
                    android:text="Reset"
                    android:textAllCaps="false"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- ⭐ 新增：TTS速度和音量拖动条 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="vertical">

                <!-- 速度拖动条 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="速度:"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/tts_speed_seekbar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="5" />

                    <TextView
                        android:id="@+id/tts_speed_value"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="1.0x"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 音量拖动条 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="音量:"
                        android:textSize="12sp" />

                    <SeekBar
                        android:id="@+id/tts_volume_seekbar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="9" />

                    <TextView
                        android:id="@+id/tts_volume_value"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="1.0"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ⭐ 新增：管理Edge-TTS缓存按钮 -->
            <Button
                android:id="@+id/btn_manage_edge_tts_cache"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="管理Edge-TTS缓存（查看/删除）"
                android:textAllCaps="false"
                android:textSize="@dimen/text_caption"
                android:backgroundTint="#FF5722" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
