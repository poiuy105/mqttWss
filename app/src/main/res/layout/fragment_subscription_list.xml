<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:name="io.emqx.mqtt.SubscriptionFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_md"
    tools:context=".SubscriptionFragment"
    tools:listitem="@layout/item_subscription">

    <!-- 左侧：标题+按钮 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingEnd="@dimen/spacing_md">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subscription"
            android:textColor="?attr/colorPrimary"
            android:textSize="@dimen/text_h1"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_add_subscription"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="+"
            android:textSize="@dimen/text_h1"
            android:textAllCaps="false" />
    </LinearLayout>

    <!-- 右侧：RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/subscription_list"
        android:name="io.emqx.mqtt.SubscriptionFragment"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        app:layoutManager="LinearLayoutManager" />

</LinearLayout>