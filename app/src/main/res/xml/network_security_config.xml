<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许所有明文HTTP通信 (用于访问局域网Home Assistant等) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
